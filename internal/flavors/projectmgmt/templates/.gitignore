# Office app lock files (created when a .docx / .pptx / .xlsx is open)
~$*

# OneDrive / Dropbox / OS metadata
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# Editor backups
*.swp
*.swo
*.bak
*~

# Local secrets — never commit .env files containing MCP server credentials
.env
.env.*
!.env.example

# Local-only Claude / Codex artifacts
.claude/sessions/
.claude/REVIEW.md
*.log
