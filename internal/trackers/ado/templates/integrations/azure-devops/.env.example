# Azure DevOps tracker credentials — copy to .env (gitignored) and fill in.
# Never commit the real values. .mcp.json references these via ${env:...}.
#
# ADO_ORG_URL — your organization URL, e.g. https://dev.azure.com/yourorg.
# ADO_PROJECT — the project name within that org.
# ADO_PAT     — Personal Access Token (Work Items: Read & Write).
#               Generate at https://dev.azure.com/yourorg/_usersSettings/tokens.
ADO_ORG_URL=https://dev.azure.com/yourorg
ADO_PROJECT=
ADO_PAT=
