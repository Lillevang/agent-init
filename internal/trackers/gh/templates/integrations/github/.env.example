# GitHub tracker credentials — copy to .env (gitignored) and fill in.
# Never commit the real values. .mcp.json references these via ${env:...}.
#
# Preferred: reuse the gh CLI's token instead of a separate PAT:
#   gh auth status        # confirm you're logged in
#   export GITHUB_TOKEN="$(gh auth token)"
#
# Or set a classic/fine-grained PAT (scopes: repo, read:org) directly:
GITHUB_TOKEN=
