# Jira tracker credentials — copy to .env (gitignored) and fill in.
# Never commit the real values. .mcp.json references these via ${env:...}.
#
# JIRA_URL       — Atlassian Cloud or Data Center base URL.
# JIRA_USERNAME  — your Atlassian account email.
# JIRA_API_TOKEN — generate at id.atlassian.com -> Security -> API tokens.
JIRA_URL=https://yourdomain.atlassian.net
JIRA_USERNAME=
JIRA_API_TOKEN=
