{
  "name": "iac-agent",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/iac",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/iac,type=bind,consistency=cached",

  // WARNING: the mounts below grant the container read access to your host
  // cloud credentials and SSH keys. `terraform apply` and `ansible-playbook`
  // run inside this container will act AS YOU against the targets reachable
  // with those creds. Review every plan and play before running it.
  //
  // All mounts are `,readonly` on purpose. If a tool needs to write to one of
  // them (e.g. `aws sso login`), do that on the host outside the container.
  "mounts": [
    // AWS CLI credentials and config.
    // "source=${localEnv:HOME}/.aws,target=/home/vscode/.aws,type=bind,readonly",

    // gcloud CLI credentials.
    // "source=${localEnv:HOME}/.config/gcloud,target=/home/vscode/.config/gcloud,type=bind,readonly",

    // Azure CLI cache.
    // "source=${localEnv:HOME}/.azure,target=/home/vscode/.azure,type=bind,readonly",

    // SSH keys (for Ansible). Prefer ssh-agent forwarding for production work
    // — bind-mounting the directory exposes ALL your keys to the container.
    // "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",

    // Sibling repos as peers of the workspace (read-only by default).
    // "source=${localEnv:HOME}/repos/tools/other-repo,target=/workspaces/other-repo,type=bind,readonly"
  ],

  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "GH_TOKEN": "${localEnv:GH_TOKEN}",
    "AWS_PROFILE": "${localEnv:AWS_PROFILE}",
    "AWS_REGION": "${localEnv:AWS_REGION}"
  },

  "postCreateCommand": "/usr/local/bin/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "openai.chatgpt",
        "anthropic.claude-code",
        "hashicorp.terraform",
        "redhat.ansible",
        "redhat.vscode-yaml"
      ]
    }
  }
}
