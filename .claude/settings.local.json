      "Bash(git ls-tree *)",
      "Bash(just smoke-test-update *)",
      "Bash(./.agent/scripts/check.sh)",
      "Bash(go vet *)",
      "Bash(go test *)",
      "Bash(mkdir -p 'internal/flavors/gocli/templates/cmd/{{.ProjectName}}')",
