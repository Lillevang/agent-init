      "Bash(go build *)",
      "Bash(mv 'internal/flavors/gocli/templates/cmd/{{.ProjectName}}/main.go' 'internal/flavors/gocli/templates/cmd/{{.ProjectName}}/main.go.tmpl' && go build ./... 2>&1 | tail -5 && echo OK)",
      "Bash(mkdir -p .claude/skills/add-flavor .claude/skills/feature-doc)"
    ],
    "additionalDirectories": [
      "/workspaces/agent-init/internal/flavors/gocli/templates/cmd/{{.ProjectName}}",
      "/workspaces/agent-init/.claude/skills"
    ]
  }
}
